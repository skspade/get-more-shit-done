{
  "name": "get-more-shit-done-cc",
  "version": "3.5.0",
  "description": "A meta-prompting, context engineering and spec-driven development system for Claude Code, OpenCode, Gemini and Codex.",
  "bin": {
    "get-more-shit-done-cc": "bin/install.js",
    "gsd": "get-shit-done/bin/gsd-cli.cjs",
    "gmsd": "get-shit-done/bin/gsd-cli.cjs"
  },
  "author": "skspade",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skspade/get-more-shit-done.git"
  },
  "homepage": "https://github.com/skspade/get-more-shit-done",
  "bugs": {
    "url": "https://github.com/skspade/get-more-shit-done/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6",
    "zx": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "c8": "^11.0.0",
    "esbuild": "^0.24.0"
  },
  "scripts": {
    "build:hooks": "node scripts/build-hooks.js",
    "test": "node scripts/run-tests.cjs",
    "test:coverage": "c8 --check-coverage --lines 70 --reporter text --include 'get-shit-done/bin/lib/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs",
